# 设计演化档案 - 环境变量配置示例
# 复制此文件为 .env 并填写真实的 API Key

# OpenAI API Key (用于 LLM 设计意图分析)
OPENAI_API_KEY=your-api-key-here

# Anthropic API Key (可选，用于 Claude 模型)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# LLM 模型配置
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=gpt-4o-mini

# LLM Provider: openai | anthropic | openrouter
LLM_PROVIDER=openai

# OpenRouter Base URL (仅当 provider=openrouter 时使用)
# 官方地址: https://openrouter.ai/api/v1
# 镜像地址（如无法访问官方）: https://api.openrouter-proxy.com/v1
OPENROUTER_BASE_URL=https://api.openrouter.ai/v1
